{
  "name": "navi",
  "rules": {
    "source_file": {
      "type": "REPEAT",
      "content": {
        "type": "SYMBOL",
        "name": "_line"
      }
    },
    "_line": {
      "type": "SEQ",
      "members": [
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "PREC",
              "value": 2,
              "content": {
                "type": "SYMBOL",
                "name": "tags"
              }
            },
            {
              "type": "PREC",
              "value": 2,
              "content": {
                "type": "SYMBOL",
                "name": "comment"
              }
            },
            {
              "type": "PREC",
              "value": 2,
              "content": {
                "type": "SYMBOL",
                "name": "description"
              }
            },
            {
              "type": "PREC",
              "value": 2,
              "content": {
                "type": "SYMBOL",
                "name": "variable"
              }
            },
            {
              "type": "PREC",
              "value": 2,
              "content": {
                "type": "SYMBOL",
                "name": "authorship"
              }
            },
            {
              "type": "PREC",
              "value": 1,
              "content": {
                "type": "SYMBOL",
                "name": "command"
              }
            },
            {
              "type": "SYMBOL",
              "name": "_blank"
            }
          ]
        },
        {
          "type": "PATTERN",
          "value": "\\r?\\n"
        }
      ]
    },
    "_blank": {
      "type": "TOKEN",
      "content": {
        "type": "PREC",
        "value": -1,
        "content": {
          "type": "PATTERN",
          "value": "[ \\t]*"
        }
      }
    },
    "tags": {
      "type": "SEQ",
      "members": [
        {
          "type": "FIELD",
          "name": "marker",
          "content": {
            "type": "ALIAS",
            "content": {
              "type": "STRING",
              "value": "%"
            },
            "named": true,
            "value": "marker"
          }
        },
        {
          "type": "REPEAT1",
          "content": {
            "type": "SYMBOL",
            "name": "tag"
          }
        }
      ]
    },
    "tag": {
      "type": "PATTERN",
      "value": "[^\\s][^\\s]*"
    },
    "comment": {
      "type": "SEQ",
      "members": [
        {
          "type": "FIELD",
          "name": "marker",
          "content": {
            "type": "ALIAS",
            "content": {
              "type": "STRING",
              "value": ";"
            },
            "named": true,
            "value": "marker"
          }
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SYMBOL",
              "name": "text"
            },
            {
              "type": "BLANK"
            }
          ]
        }
      ]
    },
    "description": {
      "type": "SEQ",
      "members": [
        {
          "type": "FIELD",
          "name": "marker",
          "content": {
            "type": "ALIAS",
            "content": {
              "type": "STRING",
              "value": "#"
            },
            "named": true,
            "value": "marker"
          }
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SYMBOL",
              "name": "text"
            },
            {
              "type": "BLANK"
            }
          ]
        }
      ]
    },
    "authorship": {
      "type": "SEQ",
      "members": [
        {
          "type": "FIELD",
          "name": "marker",
          "content": {
            "type": "ALIAS",
            "content": {
              "type": "STRING",
              "value": "@"
            },
            "named": true,
            "value": "marker"
          }
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SYMBOL",
              "name": "text"
            },
            {
              "type": "BLANK"
            }
          ]
        }
      ]
    },
    "variable": {
      "type": "SEQ",
      "members": [
        {
          "type": "FIELD",
          "name": "marker",
          "content": {
            "type": "ALIAS",
            "content": {
              "type": "STRING",
              "value": "$"
            },
            "named": true,
            "value": "marker"
          }
        },
        {
          "type": "FIELD",
          "name": "name",
          "content": {
            "type": "SYMBOL",
            "name": "var_name"
          }
        },
        {
          "type": "STRING",
          "value": ":"
        },
        {
          "type": "FIELD",
          "name": "command",
          "content": {
            "type": "CHOICE",
            "members": [
              {
                "type": "SYMBOL",
                "name": "var_command"
              },
              {
                "type": "BLANK"
              }
            ]
          }
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SEQ",
              "members": [
                {
                  "type": "STRING",
                  "value": "---"
                },
                {
                  "type": "FIELD",
                  "name": "options",
                  "content": {
                    "type": "CHOICE",
                    "members": [
                      {
                        "type": "SYMBOL",
                        "name": "var_options"
                      },
                      {
                        "type": "BLANK"
                      }
                    ]
                  }
                }
              ]
            },
            {
              "type": "BLANK"
            }
          ]
        }
      ]
    },
    "var_name": {
      "type": "PATTERN",
      "value": "[A-Za-z_][A-Za-z0-9_]*"
    },
    "var_command": {
      "type": "REPEAT1",
      "content": {
        "type": "CHOICE",
        "members": [
          {
            "type": "TOKEN",
            "content": {
              "type": "PATTERN",
              "value": "[^\\n-]+"
            }
          },
          {
            "type": "TOKEN",
            "content": {
              "type": "PREC",
              "value": -1,
              "content": {
                "type": "STRING",
                "value": "-"
              }
            }
          }
        ]
      }
    },
    "var_options": {
      "type": "PATTERN",
      "value": "[^\\n]+"
    },
    "command": {
      "type": "PREC_RIGHT",
      "value": 0,
      "content": {
        "type": "REPEAT1",
        "content": {
          "type": "CHOICE",
          "members": [
            {
              "type": "SYMBOL",
              "name": "placeholder"
            },
            {
              "type": "SYMBOL",
              "name": "command_text"
            }
          ]
        }
      }
    },
    "placeholder": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "<"
        },
        {
          "type": "SYMBOL",
          "name": "var_ref"
        },
        {
          "type": "STRING",
          "value": ">"
        }
      ]
    },
    "var_ref": {
      "type": "PATTERN",
      "value": "[A-Za-z_][A-Za-z0-9_]*"
    },
    "command_text": {
      "type": "TOKEN",
      "content": {
        "type": "PATTERN",
        "value": "[^%;#$@< \\t\\n][^<\\n]*"
      }
    },
    "text": {
      "type": "PATTERN",
      "value": "[^\\n]+"
    }
  },
  "extras": [
    {
      "type": "PATTERN",
      "value": "[ \\t]"
    }
  ],
  "conflicts": [],
  "precedences": [],
  "externals": [],
  "inline": [],
  "supertypes": []
}
